# =============================================================================
# MAGTU Consultant — Environment Variables
# Скопируй этот файл в .env и заполни значения
# =============================================================================

# App
APP_ENV=production
LOG_LEVEL=INFO

# vLLM — LLM
VLLM_LLM_BASE_URL=http://vllm_llm:8000/v1
VLLM_LLM_MODEL=/mnt/mishutqa/PycharmProjects/abitBot/app/models/Qwen3-30B-A3B-Instruct-2507-AWQ-4bit
VLLM_LLM_MAX_TOKENS=16384
VLLM_LLM_MAX_CONCURRENT=5
VLLM_LLM_TIMEOUT=60

# vLLM — Embedder
VLLM_EMBEDDER_BASE_URL=http://vllm_embedder:8001/v1
VLLM_EMBEDDER_MODEL=/mnt/mishutqa/PycharmProjects/abitBot/app/models/deepvk
EMBEDDING_DEVICE=cpu
# При EMBEDDING_DEVICE=cpu установи: EMBEDDING_CUDA_VISIBLE_DEVICES=""
# При EMBEDDING_DEVICE=cuda установи: EMBEDDING_CUDA_VISIBLE_DEVICES=0
EMBEDDING_CUDA_VISIBLE_DEVICES=

# HuggingFace cache (путь к директории с моделями)
HF_CACHE_DIR=~/.cache/huggingface

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=magtu_documents
QDRANT_TOP_K=5

# PostgreSQL
POSTGRES_USER=magtu
POSTGRES_PASSWORD=qwerty123
POSTGRES_DB=magtu_consultant
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Circuit Breaker
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30

# Agent / RAG
SQL_MAX_RETRIES=3
SQL_SAMPLE_LIMIT=10
SQL_DISTINCT_LIMIT=30
HISTORY_MAX_PAIRS=5

# Node timeouts (секунды)
TIMEOUT_LOAD_HISTORY=3
TIMEOUT_ROUTER=10
TIMEOUT_TABLE_SELECTOR=10
TIMEOUT_SAMPLE_DATA=5
TIMEOUT_SQL_GENERATOR=15
TIMEOUT_SQL_VALIDATOR=1
TIMEOUT_SQL_EXECUTOR=5
TIMEOUT_QDRANT_SEARCH=5
TIMEOUT_ANSWER_GENERATOR=20
TIMEOUT_SAVE_HISTORY=3
